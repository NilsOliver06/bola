<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Mi Inventario</title>

    <!-- Bootstrap 5.3 (moderno) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons (para íconos bonitos) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- Fuente moderna Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">

    <!-- Estilos personalizados -->
    <style>
            * {
                font-family: 'Inter', sans-serif;
            }

            body {
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                min-height: 100vh;
                padding-bottom: 2rem;
            }

            .navbar {
                box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            }

            .card-custom {
                border: none;
                border-radius: 1rem;
                box-shadow: 0 10px 30px rgba(0,0,0,0.1);
                transition: transform 0.2s, box-shadow 0.2s;
            }

                .card-custom:hover {
                    transform: translateY(-5px);
                    box-shadow: 0 15px 40px rgba(0,0,0,0.15);
                }

            .btn-custom-primary {
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                border: none;
                color: white;
                border-radius: 2rem;
                padding: 0.5rem 1.5rem;
                transition: all 0.3s;
            }

                .btn-custom-primary:hover {
                    transform: scale(1.05);
                    box-shadow: 0 5px 15px rgba(102,126,234,0.4);
                    color: white;
                }

            .table-modern {
                border-radius: 1rem;
                overflow: hidden;
            }

            .badge-stock {
                padding: 0.5rem 1rem;
                border-radius: 2rem;
                font-weight: 500;
            }

            footer {
                background: transparent;
                color: rgba(255,255,255,0.8);
                text-align: center;
                margin-top: 3rem;
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-box-seam me-2"></i>Mi Inventario
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="ProductosView" asp-action="Index">
                                <i class="bi bi-grid-3x3-gap-fill me-1"></i>Productos
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Tienda" asp-action="Index">
                                <i class="bi bi-shop me-1"></i>Tienda
                            </a>
                        </li>

                        @if (!string.IsNullOrEmpty(Context.Session.GetString("UsuarioId")))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right me-1"></i>Cerrar Sesión
                                </a>
                            </li>
                        }
                    </ul>
                    @if (!string.IsNullOrEmpty(Context.Session.GetString("UsuarioId")))
                    {
                        <span class="navbar-text text-white-50">
                            <i class="bi bi-person-circle me-1"></i>@Context.Session.GetString("UsuarioNombre")
                        </span>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="container">
            <small>© @DateTime.Now.Year - Mi Inventario Moderno</small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
